# GitHub OAuth Credentials
# Create a GitHub OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# App URL for OAuth callback (must match GitHub OAuth App settings)
APP_URL=http://localhost:8501

# Hugging Face Token (for Phase 2)
HF_TOKEN=your_huggingface_token_here

# Stripe Keys (for subscriptions)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret_here
STRIPE_PRICE_ID=price_...  # Pro plan price ID ($10/month) from Stripe dashboard

# Optional: Database URLs
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///hipstercheck.db

# Cache settings
CACHE_TTL_HOURS=24  # Review cache TTL in hours

# GitHub API Rate Limit Configuration
# Buffer of remaining requests before waiting for reset (default: 10)
RATE_LIMIT_BUFFER=10

# FastAPI Backend URL (for AI analysis)
API_URL=http://localhost:8000
